POSTGRES_DB=agent_platform
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_pass
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql://agent_user:agent_pass@postgres:5432/agent_platform
REDIS_URL=redis://redis:6379/0
TELEGRAM_INGRESS_PORT=8101
ORCHESTRATOR_PORT=8102
WORKER_RUNTIME_PORT=8103
SCHEDULER_PORT=8104
POLICY_GATEWAY_PORT=8105
ADMIN_API_PORT=8106
ADMIN_WEB_PORT=8107
LITELLM_PORT=4000
ALLOWED_TELEGRAM_USER_IDS=111111111,222222222
TELEGRAM_BOT_USERNAME=agent_bot
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
# SSH executor (optional – leave SSH_HOST empty to disable)
SSH_HOST=
SSH_PORT=22
SSH_USER=root
SSH_KEY_FILE=/run/secrets/ssh_key
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30
SSH_HOST_KEY_POLICY=auto_add
# LiteLLM
LITELLM_API_KEY=sk-litellm-key
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-master-litellm

# Redis streams
INGRESS_STREAM=ingress.accepted
DISPATCH_STREAM=orchestration.dispatched
COMPLETION_STREAM=worker.completed
NOTIFICATION_STREAM=notification.requested
DEAD_LETTER_STREAM=dead.letter

# Idempotency TTL (seconds)
IDEMPOTENCY_TTL_SECONDS=7200

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=30
